rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Structure par société : /societes/{societeId}/...
    match /societes/{societeId} {

      // Bons d'intervention par société — SUPPRESSION INTERDITE
      match /bons/{bonId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false;
      }

      // Clients par société
      match /clients/{clientId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }

      // Compteurs par société
      match /compteurs/{compteurId} {
        allow read: if true;
        allow write: if true;
      }

      // Paramètres par société (techniciens, codes d'accès, etc.)
      match /parametres/{docId} {
        allow read, write: if true;
      }

      // Astreintes par société (samedis, émis par admin)
      match /astreintes/{docId} {
        allow read, write: if true;
      }

      // Catalogue personnalisé (lignes perso enregistrées dans une catégorie)
      match /catalogue_perso/{docId} {
        allow read, write: if true;
      }
    }

    // Ancienne structure (pour compatibilité) — SUPPRESSION INTERDITE
    match /bons/{bonId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /compteurs/{compteurId} {
      allow read: if true;
      allow write: if true;
    }

    // Clients Pennylane (sync automatique)
    match /clientsPennylane/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Paiements GoCardless
    match /paiements/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Bloquer l'accès à toutes les autres collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
