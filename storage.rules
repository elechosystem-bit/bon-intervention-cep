rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Photos des bons d'intervention
    match /bons/{bonId}/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // Rapports Apave (PDF clients CEP)
    match /apave/{societeId}/{clientId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bloquer l'accès à tous les autres fichiers
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}


